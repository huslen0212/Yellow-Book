generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Place {
  id          Int     @id @default(autoincrement())
  name        String
  foundedYear Int?
  imageUrl    String?
  description String?
  location    String?
  category String?
}
